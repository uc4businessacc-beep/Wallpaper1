<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/title_settings"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="⚙"
                android:textSize="20sp"
                android:gravity="center" />
        </LinearLayout>

        <!-- Clock Display card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/dark_surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="62dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="18dp"
                    android:paddingEnd="14dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Lock screen clock"
                        android:textColor="@color/light_text"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_lock_clock"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="@color/accent"
                        android:trackTint="@color/black" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1A1A1A"
                    android:layout_marginStart="18dp"
                    android:layout_marginEnd="18dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="62dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="18dp"
                    android:paddingEnd="14dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Home screen clock"
                        android:textColor="@color/light_text"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_home_clock"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="@color/accent"
                        android:trackTint="@color/black" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1A1A1A"
                    android:layout_marginStart="18dp"
                    android:layout_marginEnd="18dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="62dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="18dp"
                    android:paddingEnd="14dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="24-hour format"
                        android:textColor="@color/light_text"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_24hour"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="@color/accent"
                        android:trackTint="@color/black" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Clock Animation card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/dark_surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Clock animation"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_clock_anim"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="@color/accent"
                        android:trackTint="@color/black" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_anim_style"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Style"
                        android:textColor="@color/light_text"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none">

                        <RadioGroup
                            android:id="@+id/radio_anim_style"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <RadioButton
                                android:id="@+id/anim_style_0"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:text="Fade"
                                android:textSize="12sp"
                                android:button="@null"
                                android:gravity="center"
                                android:paddingStart="14dp"
                                android:paddingEnd="14dp"
                                android:layout_marginEnd="6dp"
                                android:background="@drawable/chip_yellow_selector"
                                android:textColor="@drawable/chip_yellow_text_selector" />

                            <RadioButton
                                android:id="@+id/anim_style_1"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:text="Slide Up"
                                android:textSize="12sp"
                                android:button="@null"
                                android:gravity="center"
                                android:paddingStart="14dp"
                                android:paddingEnd="14dp"
                                android:layout_marginEnd="6dp"
                                android:background="@drawable/chip_yellow_selector"
                                android:textColor="@drawable/chip_yellow_text_selector" />

                            <RadioButton
                                android:id="@+id/anim_style_2"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:text="Slide Down"
                                android:textSize="12sp"
                                android:button="@null"
                                android:gravity="center"
                                android:paddingStart="14dp"
                                android:paddingEnd="14dp"
                                android:layout_marginEnd="6dp"
                                android:background="@drawable/chip_yellow_selector"
                                android:textColor="@drawable/chip_yellow_text_selector" />

                            <RadioButton
                                android:id="@+id/anim_style_3"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:text="Slide Left"
                                android:textSize="12sp"
                                android:button="@null"
                                android:gravity="center"
                                android:paddingStart="14dp"
                                android:paddingEnd="14dp"
                                android:layout_marginEnd="6dp"
                                android:background="@drawable/chip_yellow_selector"
                                android:textColor="@drawable/chip_yellow_text_selector" />

                            <RadioButton
                                android:id="@+id/anim_style_4"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:text="Slide Right"
                                android:textSize="12sp"
                                android:button="@null"
                                android:gravity="center"
                                android:paddingStart="14dp"
                                android:paddingEnd="14dp"
                                android:layout_marginEnd="6dp"
                                android:background="@drawable/chip_yellow_selector"
                                android:textColor="@drawable/chip_yellow_text_selector" />

                            <RadioButton
                                android:id="@+id/anim_style_5"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:text="Stretch V"
                                android:textSize="12sp"
                                android:button="@null"
                                android:gravity="center"
                                android:paddingStart="14dp"
                                android:paddingEnd="14dp"
                                android:layout_marginEnd="6dp"
                                android:background="@drawable/chip_yellow_selector"
                                android:textColor="@drawable/chip_yellow_text_selector" />

                            <RadioButton
                                android:id="@+id/anim_style_6"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:text="Stretch In"
                                android:textSize="12sp"
                                android:button="@null"
                                android:gravity="center"
                                android:paddingStart="14dp"
                                android:paddingEnd="14dp"
                                android:layout_marginEnd="6dp"
                                android:background="@drawable/chip_yellow_selector"
                                android:textColor="@drawable/chip_yellow_text_selector" />

                            <RadioButton
                                android:id="@+id/anim_style_7"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:text="Parallax"
                                android:textSize="12sp"
                                android:button="@null"
                                android:gravity="center"
                                android:paddingStart="14dp"
                                android:paddingEnd="14dp"
                                android:background="@drawable/chip_yellow_selector"
                                android:textColor="@drawable/chip_yellow_text_selector" />

                        </RadioGroup>
                    </HorizontalScrollView>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Speed"
                        android:textColor="@color/light_text"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="6dp">

                        <SeekBar
                            android:id="@+id/seek_anim_speed"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:max="100" />

                        <TextView
                            android:id="@+id/tv_anim_speed_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:textColor="@color/accent"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:text="Normal" />
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Motion card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/dark_surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Motion"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_gyro_enabled"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Gyroscope effect"
                    android:textColor="@color/light_text"
                    android:thumbTint="@color/accent"
                    android:trackTint="@color/black" />

                <LinearLayout
                    android:id="@+id/layout_gyro_controls"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Mode"
                        android:textColor="@color/light_text"
                        android:textStyle="bold" />

                    <RadioGroup
                        android:id="@+id/radio_motion_mode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp">

                        <RadioButton
                            android:id="@+id/radio_motion_tilt"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3D Tilt"
                            android:textColor="@color/light_text" />

                        <RadioButton
                            android:id="@+id/radio_motion_shift"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Shift"
                            android:textColor="@color/light_text"
                            android:layout_marginStart="16dp" />
                    </RadioGroup>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Sensitivity"
                        android:textColor="@color/light_text"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="6dp">

                        <SeekBar
                            android:id="@+id/seek_motion_sensitivity"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:max="100" />

                        <TextView
                            android:id="@+id/tv_sens_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:textColor="@color/accent"
                            android:textStyle="bold"
                            android:text="50" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Amount"
                        android:textColor="@color/light_text"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="6dp">

                        <SeekBar
                            android:id="@+id/seek_motion_amount"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:max="200" />

                        <TextView
                            android:id="@+id/tv_amount_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:textColor="@color/accent"
                            android:textStyle="bold"
                            android:text="80" />
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Admin card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/dark_surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/row_open_admin"
                    android:layout_width="match_parent"
                    android:layout_height="62dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="18dp"
                    android:paddingEnd="14dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Admin panel"
                        android:textColor="@color/light_text"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="@color/accent"
                        android:textSize="22sp" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>

