<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#070707" android:scrollbars="none">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="14dp" android:paddingTop="10dp">

        <!-- TEXT SHADOW -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/studio_card_bg"
            android:padding="16dp" android:layout_marginBottom="10dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="TEXT SHADOW" android:textColor="#55FFFFFF" android:textSize="9sp"
                        android:letterSpacing="0.16" android:fontFamily="sans-serif-medium" android:layout_marginBottom="3dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Drop shadow beneath text" android:textColor="#35FFFFFF" android:textSize="11sp"/>
                </LinearLayout>
                <androidx.appcompat.widget.SwitchCompat android:id="@+id/sw_shadow"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp" android:trackTint="@drawable/switch_track_studio"
                    android:thumbTint="#FFFFFFFF"/>
                <TextView android:id="@+id/btn_reset_shadow"
                    android:layout_width="@dimen/studio_reset_touch" android:layout_height="@dimen/studio_reset_touch"
                    android:text="↺" android:textColor="@color/accent" android:textSize="@dimen/studio_reset_icon"
                    android:gravity="center" android:background="@drawable/studio_reset_bg"
                    android:clickable="true" android:focusable="true"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/layout_shadow_controls"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:visibility="gone" android:layout_marginTop="14dp">

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#0CFFFFFF" android:layout_marginBottom="14dp"/>

                <!-- Shadow Opacity -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="6dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="OPACITY" android:textColor="#55FFFFFF" android:textSize="9sp"
                            android:letterSpacing="0.16" android:fontFamily="sans-serif-medium"/>
                        <TextView android:id="@+id/tv_shadow_opacity_val"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="100%" android:textColor="#FFE84C3D" android:textSize="20sp"
                            android:fontFamily="sans-serif-light"/>
                    </LinearLayout>
                    <TextView android:id="@+id/btn_minus_shadow_opacity"
                        android:layout_width="@dimen/studio_reset_touch" android:layout_height="@dimen/studio_reset_touch"
                        android:text="−" android:textColor="@color/accent" android:textSize="@dimen/studio_reset_icon"
                        android:gravity="center" android:background="@drawable/studio_reset_bg"
                        android:clickable="true" android:focusable="true" android:layout_marginEnd="4dp"/>
                    <TextView android:id="@+id/btn_reset_shadow_opacity"
                        android:layout_width="@dimen/studio_reset_touch" android:layout_height="@dimen/studio_reset_touch"
                        android:text="↺" android:textColor="@color/accent" android:textSize="@dimen/studio_reset_icon"
                        android:gravity="center" android:background="@drawable/studio_reset_bg"
                        android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/btn_plus_shadow_opacity"
                        android:layout_width="@dimen/studio_reset_touch" android:layout_height="@dimen/studio_reset_touch"
                        android:text="+" android:textColor="@color/accent" android:textSize="@dimen/studio_reset_icon"
                        android:gravity="center" android:background="@drawable/studio_reset_bg"
                        android:clickable="true" android:focusable="true" android:layout_marginStart="4dp"/>
                </LinearLayout>
                <SeekBar android:id="@+id/seek_shadow_opacity"
                    android:layout_width="match_parent" android:layout_height="36dp"
                    android:max="100" android:progress="100"
                    android:progressDrawable="@drawable/seekbar_track_studio"
                    android:thumb="@drawable/seekbar_thumb_studio" android:thumbOffset="0dp"
                    android:paddingStart="0dp" android:paddingEnd="0dp"
                    android:layout_marginBottom="14dp"/>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#0CFFFFFF" android:layout_marginBottom="14dp"/>

                <!-- Shadow Offset X -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="6dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="OFFSET X" android:textColor="#55FFFFFF" android:textSize="9sp"
                            android:letterSpacing="0.16" android:fontFamily="sans-serif-medium"/>
                        <TextView android:id="@+id/tv_shadow_x_val"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="4" android:textColor="#FFE84C3D" android:textSize="20sp"
                            android:fontFamily="sans-serif-light"/>
                    </LinearLayout>
                    <TextView android:id="@+id/btn_minus_shadow_x"
                        android:layout_width="@dimen/studio_reset_touch" android:layout_height="@dimen/studio_reset_touch"
                        android:text="−" android:textColor="@color/accent" android:textSize="@dimen/studio_reset_icon"
                        android:gravity="center" android:background="@drawable/studio_reset_bg"
                        android:clickable="true" android:focusable="true" android:layout_marginEnd="4dp"/>
                    <TextView android:id="@+id/btn_reset_shadow_x"
                        android:layout_width="@dimen/studio_reset_touch" android:layout_height="@dimen/studio_reset_touch"
                        android:text="↺" android:textColor="@color/accent" android:textSize="@dimen/studio_reset_icon"
                        android:gravity="center" android:background="@drawable/studio_reset_bg"
                        android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/btn_plus_shadow_x"
                        android:layout_width="@dimen/studio_reset_touch" android:layout_height="@dimen/studio_reset_touch"
                        android:text="+" android:textColor="@color/accent" android:textSize="@dimen/studio_reset_icon"
                        android:gravity="center" android:background="@drawable/studio_reset_bg"
                        android:clickable="true" android:focusable="true" android:layout_marginStart="4dp"/>
                </LinearLayout>
                <SeekBar android:id="@+id/seek_shadow_x"
                    android:layout_width="match_parent" android:layout_height="36dp"
                    android:max="200" android:progress="104"
                    android:progressDrawable="@drawable/seekbar_track_studio"
                    android:thumb="@drawable/seekbar_thumb_studio" android:thumbOffset="0dp"
                    android:paddingStart="0dp" android:paddingEnd="0dp"
                    android:layout_marginBottom="14dp"/>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#0CFFFFFF" android:layout_marginBottom="14dp"/>

                <!-- Shadow Offset Y -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="6dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="OFFSET Y" android:textColor="#55FFFFFF" android:textSize="9sp"
                            android:letterSpacing="0.16" android:fontFamily="sans-serif-medium"/>
                        <TextView android:id="@+id/tv_shadow_y_val"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="4" android:textColor="#FFE84C3D" android:textSize="20sp"
                            android:fontFamily="sans-serif-light"/>
                    </LinearLayout>
                    <TextView android:id="@+id/btn_minus_shadow_y"
                        android:layout_width="@dimen/studio_reset_touch" android:layout_height="@dimen/studio_reset_touch"
                        android:text="−" android:textColor="@color/accent" android:textSize="@dimen/studio_reset_icon"
                        android:gravity="center" android:background="@drawable/studio_reset_bg"
                        android:clickable="true" android:focusable="true" android:layout_marginEnd="4dp"/>
                    <TextView android:id="@+id/btn_reset_shadow_y"
                        android:layout_width="@dimen/studio_reset_touch" android:layout_height="@dimen/studio_reset_touch"
                        android:text="↺" android:textColor="@color/accent" android:textSize="@dimen/studio_reset_icon"
                        android:gravity="center" android:background="@drawable/studio_reset_bg"
                        android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/btn_plus_shadow_y"
                        android:layout_width="@dimen/studio_reset_touch" android:layout_height="@dimen/studio_reset_touch"
                        android:text="+" android:textColor="@color/accent" android:textSize="@dimen/studio_reset_icon"
                        android:gravity="center" android:background="@drawable/studio_reset_bg"
                        android:clickable="true" android:focusable="true" android:layout_marginStart="4dp"/>
                </LinearLayout>
                <SeekBar android:id="@+id/seek_shadow_y"
                    android:layout_width="match_parent" android:layout_height="36dp"
                    android:max="200" android:progress="104"
                    android:progressDrawable="@drawable/seekbar_track_studio"
                    android:thumb="@drawable/seekbar_thumb_studio" android:thumbOffset="0dp"
                    android:paddingStart="0dp" android:paddingEnd="0dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- TEXT STROKE -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/studio_card_bg"
            android:padding="16dp" android:layout_marginBottom="10dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="TEXT STROKE" android:textColor="#55FFFFFF" android:textSize="9sp"
                        android:letterSpacing="0.16" android:fontFamily="sans-serif-medium" android:layout_marginBottom="3dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Outline around text" android:textColor="#35FFFFFF" android:textSize="11sp"/>
                </LinearLayout>
                <androidx.appcompat.widget.SwitchCompat android:id="@+id/sw_stroke"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp" android:trackTint="@drawable/switch_track_studio"
                    android:thumbTint="#FFFFFFFF"/>
                <!-- FIXED: unique ID for stroke toggle reset (was btn_reset_stroke, same as width reset) -->
                <TextView android:id="@+id/btn_reset_stroke_toggle"
                    android:layout_width="@dimen/studio_reset_touch" android:layout_height="@dimen/studio_reset_touch"
                    android:text="↺" android:textColor="@color/accent" android:textSize="@dimen/studio_reset_icon"
                    android:gravity="center" android:background="@drawable/studio_reset_bg"
                    android:clickable="true" android:focusable="true"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/layout_stroke_controls"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:visibility="gone" android:layout_marginTop="14dp">

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#0CFFFFFF" android:layout_marginBottom="14dp"/>

                <!-- Apply to -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="APPLY TO" android:textColor="#55FFFFFF" android:textSize="9sp"
                    android:letterSpacing="0.16" android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="6dp"/>
                <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:scrollbars="none" android:layout_marginBottom="14dp">
                    <RadioGroup android:id="@+id/rg_stroke_target"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <RadioButton android:id="@+id/rb_stroke_both"
                            android:layout_width="wrap_content" android:layout_height="38dp"
                            android:text="Both HH MM" android:textSize="12sp" android:button="@null"
                            android:gravity="center" android:paddingStart="16dp" android:paddingEnd="16dp"
                            android:layout_marginEnd="6dp" android:checked="true"
                            android:background="@drawable/chip_yellow_selector"
                            android:textColor="@drawable/chip_yellow_text_selector"/>
                        <RadioButton android:id="@+id/rb_stroke_hh"
                            android:layout_width="wrap_content" android:layout_height="38dp"
                            android:text="HH only" android:textSize="12sp" android:button="@null"
                            android:gravity="center" android:paddingStart="16dp" android:paddingEnd="16dp"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/chip_yellow_selector"
                            android:textColor="@drawable/chip_yellow_text_selector"/>
                        <RadioButton android:id="@+id/rb_stroke_mm"
                            android:layout_width="wrap_content" android:layout_height="38dp"
                            android:text="MM only" android:textSize="12sp" android:button="@null"
                            android:gravity="center" android:paddingStart="16dp" android:paddingEnd="16dp"
                            android:background="@drawable/chip_yellow_selector"
                            android:textColor="@drawable/chip_yellow_text_selector"/>
                    </RadioGroup>
                </HorizontalScrollView>

                <!-- Stroke Width -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="6dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="WIDTH" android:textColor="#55FFFFFF" android:textSize="9sp"
                            android:letterSpacing="0.16" android:fontFamily="sans-serif-medium"/>
                        <TextView android:id="@+id/tv_stroke_w_val"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="3" android:textColor="#FFE84C3D" android:textSize="20sp"
                            android:fontFamily="sans-serif-light"/>
                    </LinearLayout>
                    <TextView android:id="@+id/btn_minus_stroke_w"
                        android:layout_width="@dimen/studio_reset_touch" android:layout_height="@dimen/studio_reset_touch"
                        android:text="−" android:textColor="@color/accent" android:textSize="@dimen/studio_reset_icon"
                        android:gravity="center" android:background="@drawable/studio_reset_bg"
                        android:clickable="true" android:focusable="true" android:layout_marginEnd="4dp"/>
                    <!-- FIXED: unique ID btn_reset_stroke_w (was btn_reset_stroke, clashing with toggle) -->
                    <TextView android:id="@+id/btn_reset_stroke_w"
                        android:layout_width="@dimen/studio_reset_touch" android:layout_height="@dimen/studio_reset_touch"
                        android:text="↺" android:textColor="@color/accent" android:textSize="@dimen/studio_reset_icon"
                        android:gravity="center" android:background="@drawable/studio_reset_bg"
                        android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/btn_plus_stroke_w"
                        android:layout_width="@dimen/studio_reset_touch" android:layout_height="@dimen/studio_reset_touch"
                        android:text="+" android:textColor="@color/accent" android:textSize="@dimen/studio_reset_icon"
                        android:gravity="center" android:background="@drawable/studio_reset_bg"
                        android:clickable="true" android:focusable="true" android:layout_marginStart="4dp"/>
                </LinearLayout>
                <SeekBar android:id="@+id/seek_stroke_w"
                    android:layout_width="match_parent" android:layout_height="36dp"
                    android:max="50" android:progress="3"
                    android:progressDrawable="@drawable/seekbar_track_studio"
                    android:thumb="@drawable/seekbar_thumb_studio" android:thumbOffset="0dp"
                    android:paddingStart="0dp" android:paddingEnd="0dp"
                    android:layout_marginBottom="14dp"/>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#0CFFFFFF" android:layout_marginBottom="14dp"/>

                <!-- Stroke Color -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="STROKE COLOR" android:textColor="#55FFFFFF" android:textSize="9sp"
                    android:letterSpacing="0.16" android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="6dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <View android:id="@+id/swatch_stroke"
                        android:layout_width="28dp" android:layout_height="28dp"
                        android:background="@color/black" android:layout_marginEnd="12dp"/>
                    <com.infinity.wallpaper.ui.common.InlineColorPicker android:id="@+id/color_picker_stroke"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#0CFFFFFF" android:layout_marginTop="14dp" android:layout_marginBottom="14dp"/>

                <!-- Fill Enabled -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="FILL ENABLED" android:textColor="#55FFFFFF" android:textSize="9sp"
                            android:letterSpacing="0.16" android:fontFamily="sans-serif-medium" android:layout_marginBottom="3dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Fill colour inside stroke" android:textColor="#35FFFFFF" android:textSize="11sp"/>
                    </LinearLayout>
                    <androidx.appcompat.widget.SwitchCompat android:id="@+id/sw_fill_enabled"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp" android:trackTint="@drawable/switch_track_studio"
                        android:thumbTint="#FFFFFFFF"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- MASK OPACITY -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/studio_card_bg"
            android:padding="16dp" android:layout_marginBottom="10dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="6dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="MASK OPACITY" android:textColor="#55FFFFFF" android:textSize="9sp"
                        android:letterSpacing="0.16" android:fontFamily="sans-serif-medium"/>
                    <TextView android:id="@+id/tv_mask_opacity_val"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="100%" android:textColor="#FFE84C3D" android:textSize="20sp"
                        android:fontFamily="sans-serif-light"/>
                </LinearLayout>
                <TextView android:id="@+id/btn_minus_mask_opacity"
                    android:layout_width="@dimen/studio_reset_touch" android:layout_height="@dimen/studio_reset_touch"
                    android:text="−" android:textColor="@color/accent" android:textSize="@dimen/studio_reset_icon"
                    android:gravity="center" android:background="@drawable/studio_reset_bg"
                    android:clickable="true" android:focusable="true" android:layout_marginEnd="4dp"/>
                <TextView android:id="@+id/btn_reset_mask_opacity"
                    android:layout_width="@dimen/studio_reset_touch" android:layout_height="@dimen/studio_reset_touch"
                    android:text="↺" android:textColor="@color/accent" android:textSize="@dimen/studio_reset_icon"
                    android:gravity="center" android:background="@drawable/studio_reset_bg"
                    android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/btn_plus_mask_opacity"
                    android:layout_width="@dimen/studio_reset_touch" android:layout_height="@dimen/studio_reset_touch"
                    android:text="+" android:textColor="@color/accent" android:textSize="@dimen/studio_reset_icon"
                    android:gravity="center" android:background="@drawable/studio_reset_bg"
                    android:clickable="true" android:focusable="true" android:layout_marginStart="4dp"/>
            </LinearLayout>
            <SeekBar android:id="@+id/seek_mask_opacity"
                android:layout_width="match_parent" android:layout_height="36dp"
                android:max="100" android:progress="100"
                android:progressDrawable="@drawable/seekbar_track_studio"
                android:thumb="@drawable/seekbar_thumb_studio" android:thumbOffset="0dp"
                android:paddingStart="0dp" android:paddingEnd="0dp"/>
        </LinearLayout>

        <!-- GLOW -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/studio_card_bg"
            android:padding="16dp" android:layout_marginBottom="10dp">

            <!-- Glow Radius -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="6dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="GLOW RADIUS" android:textColor="#55FFFFFF" android:textSize="9sp"
                        android:letterSpacing="0.16" android:fontFamily="sans-serif-medium"/>
                    <TextView android:id="@+id/tv_glow_radius_val"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="#FFE84C3D" android:textSize="20sp"
                        android:fontFamily="sans-serif-light"/>
                </LinearLayout>
                <TextView android:id="@+id/btn_minus_glow_radius"
                    android:layout_width="@dimen/studio_reset_touch" android:layout_height="@dimen/studio_reset_touch"
                    android:text="−" android:textColor="@color/accent" android:textSize="@dimen/studio_reset_icon"
                    android:gravity="center" android:background="@drawable/studio_reset_bg"
                    android:clickable="true" android:focusable="true" android:layout_marginEnd="4dp"/>
                <TextView android:id="@+id/btn_reset_glow"
                    android:layout_width="@dimen/studio_reset_touch" android:layout_height="@dimen/studio_reset_touch"
                    android:text="↺" android:textColor="@color/accent" android:textSize="@dimen/studio_reset_icon"
                    android:gravity="center" android:background="@drawable/studio_reset_bg"
                    android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/btn_plus_glow_radius"
                    android:layout_width="@dimen/studio_reset_touch" android:layout_height="@dimen/studio_reset_touch"
                    android:text="+" android:textColor="@color/accent" android:textSize="@dimen/studio_reset_icon"
                    android:gravity="center" android:background="@drawable/studio_reset_bg"
                    android:clickable="true" android:focusable="true" android:layout_marginStart="4dp"/>
            </LinearLayout>
            <SeekBar android:id="@+id/seek_glow_radius"
                android:layout_width="match_parent" android:layout_height="36dp"
                android:max="200" android:progress="0"
                android:progressDrawable="@drawable/seekbar_track_studio"
                android:thumb="@drawable/seekbar_thumb_studio" android:thumbOffset="0dp"
                android:paddingStart="0dp" android:paddingEnd="0dp"/>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#0CFFFFFF" android:layout_marginTop="14dp" android:layout_marginBottom="14dp"/>

            <!-- Glow Color -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="GLOW COLOR" android:textColor="#55FFFFFF" android:textSize="9sp"
                android:letterSpacing="0.16" android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="6dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <View android:id="@+id/swatch_glow"
                    android:layout_width="28dp" android:layout_height="28dp"
                    android:background="@color/light_text" android:layout_marginEnd="12dp"/>
                <com.infinity.wallpaper.ui.common.InlineColorPicker android:id="@+id/color_picker_glow"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"/>
            </LinearLayout>
        </LinearLayout>

