<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Display Date Toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#161616"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Display Date"
                android:textColor="@color/light_text"
                android:textSize="13sp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/sw_date_visible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/btn_reset_date_visible"
                android:layout_width="@dimen/studio_reset_touch"
                android:layout_height="@dimen/studio_reset_touch"
                android:text="↺"
                android:textColor="@color/accent"
                android:textSize="@dimen/studio_reset_icon"
                android:gravity="center"
                android:background="@drawable/studio_reset_bg"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Date controls (hidden when toggle off) -->
        <LinearLayout
            android:id="@+id/layout_date_controls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Font Size -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#161616"
                android:padding="12dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Font Size"
                        android:textColor="@color/light_text"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tv_date_size_val"
                        android:layout_width="44dp"
                        android:layout_height="wrap_content"
                        android:text="40sp"
                        android:textColor="@color/accent"
                        android:textSize="12sp"
                        android:gravity="end" />

                    <TextView
                        android:id="@+id/btn_reset_date_size"
                        android:layout_width="@dimen/studio_reset_touch"
                        android:layout_height="@dimen/studio_reset_touch"
                        android:text="↺"
                        android:textColor="@color/accent"
                        android:textSize="@dimen/studio_reset_icon"
                        android:gravity="center"
                        android:background="@drawable/studio_reset_bg"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seek_date_size"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="200"
                    android:progress="40"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <!-- H Position -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#161616"
                android:padding="12dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Horizontal Position"
                        android:textColor="@color/light_text"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tv_date_x_val"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="50%"
                        android:textColor="@color/accent"
                        android:textSize="12sp"
                        android:gravity="end" />

                    <TextView
                        android:id="@+id/btn_reset_date_x"
                        android:layout_width="@dimen/studio_reset_touch"
                        android:layout_height="@dimen/studio_reset_touch"
                        android:text="↺"
                        android:textColor="@color/accent"
                        android:textSize="@dimen/studio_reset_icon"
                        android:gravity="center"
                        android:background="@drawable/studio_reset_bg"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seek_date_x"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="50"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <!-- V Position -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#161616"
                android:padding="12dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Vertical Position"
                        android:textColor="@color/light_text"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tv_date_y_val"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="75%"
                        android:textColor="@color/accent"
                        android:textSize="12sp"
                        android:gravity="end" />

                    <TextView
                        android:id="@+id/btn_reset_date_y"
                        android:layout_width="@dimen/studio_reset_touch"
                        android:layout_height="@dimen/studio_reset_touch"
                        android:text="↺"
                        android:textColor="@color/accent"
                        android:textSize="@dimen/studio_reset_icon"
                        android:gravity="center"
                        android:background="@drawable/studio_reset_bg"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seek_date_y"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="75"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <!-- Rotation -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#161616"
                android:padding="12dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Rotation"
                        android:textColor="@color/light_text"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tv_date_rot_val"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="0°"
                        android:textColor="@color/accent"
                        android:textSize="12sp"
                        android:gravity="end" />

                    <TextView
                        android:id="@+id/btn_reset_date_rot"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="↺"
                        android:textColor="@color/accent"
                        android:textSize="16sp"
                        android:paddingStart="8dp"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seek_date_rot"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="360"
                    android:progress="180"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>

