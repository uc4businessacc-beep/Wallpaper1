<resources>
    <!-- Base application theme: use a Dark Material3 parent to force dark theme across the app -->
    <style name="Base.Theme.Wallpaper" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Dark theme customizations -->
        <item name="android:colorBackground">@color/black</item>
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:navigationBarColor">@color/black</item>
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/accent_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="android:textColorPrimary">@color/light_text</item>
        <item name="android:textColorSecondary">@color/light_text</item>
        <!-- App-wide font family for clean, modern look -->
        <item name="android:fontFamily">sans-serif-condensed</item>
    </style>

    <!-- App theme (dark) -->
    <style name="Theme.Wallpaper" parent="Base.Theme.Wallpaper" />

    <!-- Launch (splash) theme with a dark background drawable -->
    <style name="Theme.Wallpaper.Splash" parent="Theme.Wallpaper">
        <!-- Use a solid color for the launch background to avoid resource resolution issues -->
        <item name="android:windowBackground">@color/black</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- Dialog theme for the download popup: transparent window with centered card -->

    <!-- Studio tab label style -->
    <style name="StudioTabText" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">11sp</item>
        <item name="textAllCaps">false</item>
        <item name="android:letterSpacing">0.02</item>
    </style>


</resources>